# ─────────────────────────────────────────────
# Bar-Tech AI MVP — Environment Configuration
# Copy this to .env and fill in all values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# ── AI (OpenAI or Azure OpenAI) ──────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Azure OpenAI (optional — leave blank to use OpenAI directly)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Chatwoot ──────────────────────────────────
CHATWOOT_API_URL=https://chat.yourdomain.com
CHATWOOT_API_TOKEN=your_chatwoot_api_token
CHATWOOT_ACCOUNT_ID=2
# Webhook signature secret — MUST match exactly what you enter in:
# Chatwoot → Settings → Integrations → Webhooks → Edit → "Webhook Token" field
# If you leave this blank here, signature verification is skipped (less secure but works)
# If you set it here, you MUST also set the same value in Chatwoot or all webhooks will be rejected
CHATWOOT_WEBHOOK_SECRET=

# Inbox IDs (find these in Chatwoot → Settings → Inboxes)
CHATWOOT_INBOX_ID=5
DEFAULT_INBOX_ID=5
CHATWOOT_EMAIL_INBOX_ID=5
CHATWOOT_SUPPORT_INBOX_ID=5
CHATWOOT_SALES_INBOX_ID=5
CHATWOOT_FLEET_INBOX_ID=5

# ── 3CX Internal Security ─────────────────────
INTERNAL_API_KEY=change_this_to_a_strong_random_key

# ── WhatsApp (Meta) ───────────────────────────
WHATSAPP_PROVIDER=meta
WHATSAPP_API_TOKEN=your_meta_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_PHONE_NUMBER=+9721234567890
WHATSAPP_VERIFY_TOKEN=your_meta_webhook_verify_token

# WhatsApp (Twilio) — only needed if WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# ── Email (SMTP + IMAP) ───────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=support@yourdomain.com
EMAIL_PASS=your_app_password_here

EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_TLS=true

# ── Server ────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# ── SLA Configuration ─────────────────────────
# First Response Time threshold in seconds (default: 300 = 5 minutes)
SLA_FRT_SECONDS=300

# ── Error Alerts ──────────────────────────────
# Option A: Telegram Bot (preferred — instant push notification)
# 1. Create a bot via @BotFather on Telegram → get BOT_TOKEN
# 2. Add the bot to a group or DM it, then get your CHAT_ID via:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# Option B: Email alert (uses the Gmail SMTP credentials above)
# Set this to the address that should receive error notifications
ALERT_EMAIL_TO=

# ── Agent Auto-Assignment on Handoff ──────────
# Chatwoot agent ID to auto-assign escalated conversations.
# Find it in Chatwoot → Settings → Agents.
# Leave blank to skip auto-assignment.
DEFAULT_ASSIGNEE_ID=

# ── Business Hours ─────────────────────────────────────────────────────────────
BUSINESS_TZ=Asia/Jerusalem
BUSINESS_OPEN_HOUR=8
BUSINESS_CLOSE_HOUR=16
BUSINESS_WORK_DAYS=0,1,2,3,4

# ── SMS for OOH notifications ──────────────────────────────────────────────────
TWILIO_SMS_NUMBER=+1XXXXXXXXXX

# ── Intent Routing ─────────────────────────────────────────────────────────────
GROUP_A_INBOX_IDS=5,6,7
DEFAULT_SUPPORT_AGENT_ID=
DEFAULT_SALES_AGENT_ID=

# ── Asterisk AMI ───────────────────────────────────────────────────────────────
ASTERISK_AMI_HOST=127.0.0.1
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USER=bartech
ASTERISK_AMI_SECRET=
CHATWOOT_PHONE_INBOX_ID=
